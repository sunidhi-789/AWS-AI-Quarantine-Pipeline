{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "AllowS3Access",
            "Effect": "Allow",
            "Action": [
                "s3:GetObject",
                "s3:PutObject",
                "s3:DeleteObject"
            ],
            "Resource": [
                "arn:aws:s3:::my-smart-media-bucket",
                "arn:aws:s3:::quarantine_bucket"
            ]
        },
        {
            "Sid": "AllowRekognitionAnalysis",
            "Effect": "Allow",
            "Action": [
                "rekognition:DetectModerationLabels"
            ],
            "Resource": "*"
        },
        {
            "Sid": "AllowLoggingAndAlerts",
            "Effect": "Allow",
            "Action": [
                "dynamodb:PutItem",
                "sns:Publish",
                "logs:CreateLogGroup",
                "logs:CreateLogStream",
                "logs:PutLogEvents"
            ],
            "Resource": "*"
        }
    ]
}
